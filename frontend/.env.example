# Frontend environment variables (used by Vite at build time)
# Copy to .env.local for local overrides

# API base URL -- defaults to /api (works when frontend and backend share a domain)
# Set to a full URL (e.g. https://api.example.com/api) if hosting frontend separately
VITE_API_URL=/api

# LiveKit server URL for video meetings.
# MUST be set or meeting rooms hang in "connecting" forever with
# "engine not connected within timeout" errors.
# We use LiveKit Cloud (not self-hosted). Get the project URL from
# the LK Cloud dashboard — looks like wss://<project>.livekit.cloud.
# Local dev (only if running self-hosted LK): ws://localhost:7880
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Hocuspocus collaboration server URL for real-time editing
# Local dev: ws://localhost:1234  |  Production: wss://yourdomain.com/collaborate/
VITE_COLLAB_URL=ws://localhost:1234
